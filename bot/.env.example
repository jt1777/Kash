# =============================================================================
# BOT ENV REFERENCE
# =============================================================================
#
# REQUIRED:
#   PRIVATE_KEY              - Bot wallet (must be contract owner)
#   Product contract addresses - set the pair for the product you run (PRODUCT selects which is used):
#     ETH: KASH_YIELD_ETH_ADDRESS, KASH_TOKEN_ETH
#     BTC: KASH_YIELD_BTC_ADDRESS, KASH_TOKEN_BTC
#   Legacy: KASH_YIELD_ADDRESS / KASH_TOKEN_ADDRESS still work as fallback when product-specific vars are unset.
#
# PRODUCT-SPECIFIC (PRODUCT=btc with MockAave):
#   PRODUCT=btc
#   AAVE_POOL_ADDRESS        - MockAave address (e.g. 0x8624f9850Af8fe940807944b4ecBaCdA541bd91f)
#   AAVE_USDC_ADDRESS        - MockUSDC address (MockAave expects this for borrow/repay)
#
# How the bot and MockAave connect:
#   The KashYieldBtc contract stores the pool address on-chain (set at deploy or via setAavePool).
#   When you deploy with deploy-kashyieldbtc.js, it reads AAVE_POOL_ADDRESS from .env and calls
#   setAavePool(AAVE_POOL_ADDRESS) so the contract uses that pool. The bot .env should use the
#   SAME pool address so scripts that read from the pool (balances, status) talk to the right contract.
#   For borrow/repay the CONTRACT calls pool.borrow(asset, amount) and pool.repay(asset, amount).
#   The "asset" is whatever the bot passes — config.aaveUsdcAddress (AAVE_USDC_ADDRESS). So
#   AAVE_USDC_ADDRESS must be the token your MockAave was deployed with (its borrow/repay token).
#
# OPTIONAL: RPC_URL, CHAIN_ID, WAIT_FOR_PROCESSING_WINDOW, AAVE_DEPOSIT_PCT, etc.
#
# Example: both ETH and BTC configured; switch product with PRODUCT=eth or PRODUCT=btc
#   PRIVATE_KEY=0x...
#   PRODUCT=eth
#   KASH_YIELD_ETH_ADDRESS=0x...
#   KASH_TOKEN_ETH=0x...
#   KASH_YIELD_BTC_ADDRESS=0x897a206c1C7494C1593C2a9b7900D8fd4EbFFD7b
#   KASH_TOKEN_BTC=0x...
#   AAVE_POOL_ADDRESS=0x8624f9850Af8fe940807944b4ecBaCdA541bd91f
#   AAVE_USDC_ADDRESS=0x97F22977cC706724980Ad50E5bA2E2A56063F92e
#   WAIT_FOR_PROCESSING_WINDOW=false
#
# =============================================================================

# Blockchain
# Use RPC_URL for explicit RPC, or ARBITRUM_SEPOLIA_RPC_URL for Sepolia testnet
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# Or use: ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

PRIVATE_KEY=0x...

# Product: eth (KashYieldETH) or btc (KashYieldBtc)
# Use PRODUCT=eth or PRODUCT=btc; the bot uses the matching *_ETH_* or *_BTC_* addresses below.
PRODUCT=eth

# Contracts - you can set both ETH and BTC; PRODUCT selects which product runs
KASH_YIELD_ETH_ADDRESS=0x...
KASH_TOKEN_ETH=0x...
KASH_YIELD_BTC_ADDRESS=0x...
KASH_TOKEN_BTC=0x...
# Legacy (optional): used as fallback when product-specific var is unset
# KASH_YIELD_ADDRESS=0x...
# KASH_TOKEN_ADDRESS=0x...

# Token Addresses (Arbitrum Sepolia Testnet)
# For mainnet addresses, see the project documentation
WETH_ADDRESS=0x89c8C8AD33c4a9539361a2Cf1A908C4300F258D9
WBTC_ADDRESS=0x4D8b720b94D341F54df948696747B05998c5FbD5
USDT_ADDRESS=0x833EdA586220B1d0C25034E9bAb5ed4B4a5769a1
USDC_ADDRESS=0x15BB91b9e63EA29863678B1dcBcB01dE31bD8Ab5

# Aave pool (or MockAaveV3 for BTC testnet)
# - ETH product / real Aave: use the real Aave V3 pool below.
# - BTC product with mock stack: use YOUR deployed MockAaveV3 address (from deploy-mock-aave.js output).
#   Your MockAaveV3 address is whatever you got when you deployed (e.g. ...055c); it is NOT the same as the real pool.
AAVE_POOL_ADDRESS=0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff

# USDC for Aave borrow/repay - when using MockAave (KashYieldBtc testnet), set to your MockUSDC address
# AAVE_USDC_ADDRESS=0x...

# Aave User Address (optional - defaults to KASH_YIELD_ADDRESS)
# Set this if the Aave vault is a separate contract from KashYield
# AAVE_USER_ADDRESS=0x...

# Chainlink Oracles (Arbitrum Sepolia Testnet)
# For mainnet addresses, see the project documentation
ETH_ORACLE_ADDRESS=0x1AdF01abD96C11AEE2f20a41a03fAD11b3D8d2b4
BTC_ORACLE_ADDRESS=0xBfFE5FE928F9597E2A21Ba8f2cDE7D2D10C09d27
USDT_ORACLE_ADDRESS=0x78a59DD416d0CE4AbfD2e27BFd2f6bFdceC446e3
USDC_ORACLE_ADDRESS=0xed45CBB45d34F53bf14C70e6FC2711bDd6454E76

# Configuration
BATCH_PROCESSING_TIME=23:50
LOG_LEVEL=info
# Set to false to exit immediately when not in processing window (23:50-23:59 UTC)
# WAIT_FOR_PROCESSING_WINDOW=false

# Set to true to run batch logic anytime (skip processing-window check) for testing.
# Contract may still revert if it enforces 23:50-23:59 UTC; use with a test contract that allows full 24h.
# SKIP_PROCESSING_WINDOW_CHECK=true

# Batch flow step. Default: full (run all 5 steps in sequence).
# Single step: phase1 | ops | nav | mark-done | phase2 (or --step=1..5). Sub-step for ops only: hl | aave.
# Example: npm start -- --step=nav   or   BATCH_STEP=phase2 npm start
# BATCH_STEP=full

# Run on a specific batch cycle (overrides auto-selection). Use for historical batches.
# Example: npm start -- --batch=20520   or   BATCH_CYCLE=20520 npm start
# BATCH_CYCLE=

# Allow running ops step on an already-processed batch (e.g. to fix HL/Aave state). Use with --batch=N and --step=ops|hl|aave.
# ALLOW_PROCESSED_BATCH=true   or   npm start -- --batch=20521 --step=hl --allow-processed

# Strategy allocation (NET_MINT / NET_REDEEM). Optional; defaults shown.
# AAVE_DEPOSIT_PCT=100   # % of net mint sent to Aave (100 = 100%)
# BORROW_LTV_PCT=70      # % of deposit value borrowed as USDC and sent to Hyperliquid (70 = 70% LTV)
# SHORT_LEVERAGE=1.7     # Short notional as multiple of net mint (1.7 = 1.7x)
