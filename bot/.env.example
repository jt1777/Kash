# =============================================================================
# BOT .env — bot operator runtime configuration
# Copy to .env and fill in values. Never commit the real .env file.
# =============================================================================
#
# REQUIRED:
#   PRIVATE_KEY              — bot operator wallet (separate from the deployer wallet)
#   RPC_URL or ARBITRUM_MAINNET_RPC_URL — Arbitrum One RPC endpoint
#   PRODUCT                  — eth | btc (selects which KashYield contract to use)
#   KASH_YIELD_ETH_ADDRESS / KASH_TOKEN_ETH   — for PRODUCT=eth
#   KASH_YIELD_BTC_ADDRESS / KASH_TOKEN_BTC   — for PRODUCT=btc
#
# OPTIONAL:
#   BATCH_STEP, BATCH_CYCLE, SKIP_PROCESSING_WINDOW_CHECK — see below
#   AAVE_DEPOSIT_PCT, BORROW_LTV_PCT, SHORT_LEVERAGE       — strategy tuning
#
# =============================================================================

# ── Bot wallet ────────────────────────────────────────────────────────────────
# Must be the botAddress set on KashYieldETH / KashYieldBtc at deploy time.
PRIVATE_KEY=0x...

# ── RPC ───────────────────────────────────────────────────────────────────────
# Mainnet
RPC_URL=https://arb1.g.alchemy.com/v2/YOUR_API_KEY
CHAIN_ID=42161
# Arbitrum Sepolia testnet — replace the above two lines with these when testing:
# RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# CHAIN_ID=421614

# ── Product ───────────────────────────────────────────────────────────────────
# Set to 'eth' or 'btc'. The bot loads the matching *_ETH_* or *_BTC_* addresses.
PRODUCT=eth

# ── Contract addresses ────────────────────────────────────────────────────────
KASH_YIELD_ETH_ADDRESS=
KASH_TOKEN_ETH=
KASH_YIELD_BTC_ADDRESS=
KASH_TOKEN_BTC=

# ── Token addresses (Arbitrum One mainnet) ────────────────────────────────────
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
WBTC_ADDRESS=0x2f2a2543B76A4166549F7aaB2e75Bef0aefC5B0f
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
AAVE_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831   # same as USDC on mainnet

# Aave pool — used by bot scripts that read state directly (balances, health factor).
# The on-chain pool address is hardcoded immutable in the KashYield contract.
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# ── Chainlink oracle addresses (Arbitrum One mainnet) ─────────────────────────
ETH_ORACLE_ADDRESS=0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
BTC_ORACLE_ADDRESS=0x6ce185860a4963106506C203335A2910413708e9

# ── Batch configuration ───────────────────────────────────────────────────────
# Processing window opens at 23:50 UTC by default (matches on-chain userWindowEnd).
BATCH_PROCESSING_TIME=23:50
LOG_LEVEL=info

# Set to false to exit immediately when outside the processing window.
# WAIT_FOR_PROCESSING_WINDOW=false

# Set to true to run batch logic at any time (skips processing-window check).
# The contract may still revert if it enforces the window on-chain.
# SKIP_PROCESSING_WINDOW_CHECK=true

# Run a specific batch step instead of the full sequence.
# Values: full | phase1 | ops | nav | mark-done | phase2
# Also accepts --step=1..5 on the command line.
# BATCH_STEP=full

# Run on a specific historical batch cycle (overrides auto-selection).
# BATCH_CYCLE=

# Allow re-running the ops step on an already-processed batch (e.g. to fix HL/Aave state).
# Use together with BATCH_CYCLE=N and BATCH_STEP=ops.
# ALLOW_PROCESSED_BATCH=true

# ── Strategy allocation ───────────────────────────────────────────────────────
# These control how the net mint/redeem is deployed. Defaults shown.
# AAVE_DEPOSIT_PCT=100    # % of net mint ETH/wBTC deposited to Aave as collateral
# BORROW_LTV_PCT=70       # % of deposit USD value borrowed as USDC and sent to Hyperliquid
# SHORT_LEVERAGE=1.7      # perp short size as multiple of the net mint value (1.7 = 1.7x)

# --- Hyperliquid off-chain relay ---
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# Private key used to sign HL API actions (prefer dedicated HL agent key, not owner key)
HYPERLIQUID_API_PRIVATE_KEY=0x...

# Enable inline HL relay during `npm start` ops flow.
# true  = execute HL API orders from on-chain intent txs (open/close/spot) and sync adapter state.
# false = only send on-chain intent txs; no real HL API trades are executed.
HL_EVENT_RELAY_ENABLED=true

# If true, fail ops step when relay execution fails.
# If false, log warning and continue on-chain flow.
HL_EVENT_RELAY_STRICT=false

# Redeem settlement guard (HL -> Arbitrum USDC arrival):
# Bot waits/retries after HL withdraw before classifying redeem tail.
# If unresolved shortfall remains after max wait, bot fails fast (no rising-tail fallback).
HL_WITHDRAW_WAIT_ENABLED=true
HL_WITHDRAW_WAIT_MAX_MS=360000
HL_WITHDRAW_WAIT_POLL_MS=20000

# Allow small expected mismatch on HL withdraw receipt (e.g. HL withdrawal fee).
# Bot requires: received + tolerance >= expected.
HL_WITHDRAW_FEE_TOLERANCE_USDC=1

# Optional override; usually leave unset.
# If adapter.directDepositMode=false, script auto-uses adapter address as HL account.
# If adapter.directDepositMode=true, script auto-uses adapter.hlAccount().
# HL_ACCOUNT_ADDRESS=0x...

# Relay behavior
WATCH=true
POLL_INTERVAL_MS=15000
CONFIRMATIONS=2

# Trading safety
HL_ORDER_SLIPPAGE_BPS=50

# Optional spot overrides (normally auto-detected)
# HL_SPOT_PAIR_NAME=ETH/USDC
# HL_SPOT_ASSET_ID=10042