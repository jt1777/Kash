# Environment variables for KASH deployment
# Copy this to .env and fill in your values

# RPC Endpoints
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_ONE_RPC=https://arb1.arbitrum.io/rpc

# Deployer Wallet (required for testnet/mainnet deployments)
# Generate a new key: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
DEPLOYER_PRIVATE_KEY=0x...

# Verification
ARBISCAN_API_KEY=your_api_key_here
