# =============================================================================
# ROOT .env — Hardhat deploy scripts & contract interactions
# Copy to .env and fill in values. Never commit the real .env file.
# =============================================================================

# ── Deployer wallet ───────────────────────────────────────────────────────────
# Used by all Hardhat scripts. Keep separate from the bot operator key.
# For KASH-BTC V3 + Aster: use a dedicated deployer — do not send other txs
# from this wallet during deploy-kash-btc-aster-stack.js (nonce prediction).
PRIVATE_KEY=0x...

# ── RPC endpoints ─────────────────────────────────────────────────────────────
ARBITRUM_MAINNET_RPC_URL=https://arb1.g.alchemy.com/v2/YOUR_API_KEY
# Pin mainnet fork to a specific block for reproducibility and RPC cache hits.
# FORK_BLOCK_NUMBER=440000000
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API v2 key (Hardhat verify + activity API) — https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key
# ARBISCAN_API_KEY=

# ── Bot wallet ────────────────────────────────────────────────────────────────
# Address only — private key stays in bot/.env
BOT_ADDRESS=0x...

# ── Fee recipient (KashYieldETH + KashYieldBtc V3) ───────────────────────────
# Receives protocol fees (wBTC/ETH) each batch. Defaults to deployer if unset.
FEE_RECEIVER_ADDRESS=0x...

# ── Token addresses ───────────────────────────────────────────────────────────
# Arbitrum One (mainnet)
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831   # native USDC (not USDC.e)
WBTC_ADDRESS=0x2f2a2543B76A4166549F7aaB2e75Bef0aefC5B0f

# Arbitrum Sepolia (testnet)
# WETH_ADDRESS=0x980B62Da83eFf3D4576C647993b0c1D7faf17c73
# USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
# WBTC_ADDRESS=<testnet wBTC address>

# ── Protocol addresses (Arbitrum One mainnet) ─────────────────────────────────
# Aave V3 pool is hardcoded in KashYield constructors (reference for ops scripts).
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# Uniswap V3 SwapRouter02 (deploy-uniswap-adapter.js)
UNISWAP_ROUTER_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# Hyperliquid Bridge2 (HyperliquidAdapter only — not used for Aster)
HL_BRIDGE_ADDRESS=0x2Df1c51E09aECF9cacB7bc98cB1742757f163dF7

# Chainlink price feeds
ETH_ORACLE_ADDRESS=0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
BTC_ORACLE_ADDRESS=0x6ce185860a4963106506C203335A2910413708e9
# Alias read by some scripts:
# BTC_ORACLE=0x6ce185860a4963106506C203335A2910413708e9

# ── KASH-BTC V3 + Aster (recommended — one atomic deploy) ─────────────────────
#   npm run deploy:btc-aster
#   npx hardhat run scripts/deploy-kash-btc-aster-stack.js --network arbitrumOne
#
# Deploys AsterAdapter + ExchangeFacade + KashYieldBtc in one run (nonce prediction).
# Required before deploy:
ASTER_VAULT=
ASTER_ACCOUNT_BALANCE=
ASTER_BASE_TOKEN=
SPOT_DEX_ADDRESS=              # UniswapV3Adapter — deploy first via deploy-uniswap-adapter.js
#
# Optional Aster overrides:
# ASTER_CLEARING_HOUSE=0x9E36CB86a159d479cEd94Fa05036f235Ac40E1d5
# EXCHANGE_NAME=ASTER
# KEEPER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
# CYCLE_DURATION_SECONDS=86400
# USER_WINDOW_END=85500
# PROCESSING_WINDOW_START=85500
# FEE_BPS=3
# MAX_SWAP_SLIPPAGE_BPS=100

# ── KASH-BTC V3 + Hyperliquid (legacy multi-step) ─────────────────────────────
# 1. deploy-uniswap-adapter.js  → SPOT_DEX_ADDRESS
# 2. deploy-hyperliquid-adapter.js (IS_ETH_ASSET=false) → HL_ADAPTER_ADDRESS_BTC
# 3. deploy-kashyieldbtc.js (EXCHANGE_NAME=HL, EXCHANGE_ADAPTER_ADDRESS=<HL adapter>)
#
# EXCHANGE_ADAPTER_ADDRESS=      # HyperliquidAdapter only (not Aster)
# EXCHANGE_NAME=HL

# ── HyperliquidAdapter (scripts/deploy-hyperliquid-adapter.js) ────────────────
# MOCK_HL_ADDRESS=0x2Df1c51E09aECF9cacB7bc98cB1742757f163dF7
#
# KashYieldETH:  IS_ETH_ASSET=true  + KASH_YIELD_ETH_ADDRESS
# KashYieldBtc:  IS_ETH_ASSET=false + KASH_YIELD_BTC_ADDRESS + WBTC_ADDRESS

# ── KashYieldETH deploy (scripts/deploy-kashyieldeth.js) ──────────────────────
# Constructor: bot, weth, usdc, feeReceiver
# Then: HyperliquidAdapter → ExchangeFacade → wire via kash-ops

# ── Deployed contract addresses (fill in after deploy) ────────────────────────
KASH_YIELD_ETH_ADDRESS=
KASH_TOKEN_ETH=
KASH_YIELD_BTC_ADDRESS=
KASH_TOKEN_BTC=

ASTER_ADAPTER_ADDRESS=
EXCHANGE_FACADE_ETH_ADDRESS=
EXCHANGE_FACADE_BTC_ADDRESS=

UNISWAP_ADAPTER_ADDRESS=
HL_ADAPTER_ADDRESS_ETH=
HL_ADAPTER_ADDRESS_BTC=

# ── Frontend (frontend/.env.local) — mirror vault/token addresses ───────────
# See frontend/.env.local.example
