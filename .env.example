# =============================================================================
# ROOT .env — Hardhat deploy scripts & contract interactions
# Copy to .env and fill in values. Never commit the real .env file.
# =============================================================================

# ── Deployer wallet ───────────────────────────────────────────────────────────
# Used by all Hardhat scripts. Keep separate from the bot operator key.
PRIVATE_KEY=0x...

# ── RPC endpoints ─────────────────────────────────────────────────────────────
ARBITRUM_MAINNET_RPC_URL=https://arb1.g.alchemy.com/v2/YOUR_API_KEY
# Pin mainnet fork to a specific block for reproducibility and RPC cache hits.
# Find a recent Arbitrum block at https://arbiscan.io  (default: 440000000)
# FORK_BLOCK_NUMBER=440000000
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Etherscan API v2 key (Hardhat verify + activity API) — create at https://etherscan.io/myapikey
# One key works for Arbiscan (Arbitrum), Etherscan (Ethereum), and other supported explorers.
ETHERSCAN_API_KEY=your_etherscan_api_key
# Legacy alias (optional if you already use ARBISCAN_API_KEY in .env)
# ARBISCAN_API_KEY=

# ── Bot wallet ────────────────────────────────────────────────────────────────
# Address only — private key stays in bot/.env
BOT_ADDRESS=0x...

# ── Token addresses ───────────────────────────────────────────────────────────
# Arbitrum One (mainnet) — canonical addresses, no mocks
WETH_ADDRESS=0x82aF49447D8a07e3bd95BD0d56f35241523fBab1
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831   # native USDC (not bridged USDC.e)
WBTC_ADDRESS=0x2f2a2543B76A4166549F7aaB2e75Bef0aefC5B0f

# Arbitrum Sepolia (testnet) — uncomment and replace the above when deploying to Sepolia
# WETH_ADDRESS=0x980B62Da83eFf3D4576C647993b0c1D7faf17c73
# USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
# WBTC_ADDRESS=<testnet wBTC address>

# ── Protocol addresses (Arbitrum One mainnet) ─────────────────────────────────
# Aave V3 — aavePoolAddress is now hardcoded immutable in KashYieldETH/BTC constructor.
# These vars are kept for reference / ops scripts that read Aave state directly.
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# Uniswap V3 SwapRouter02
UNISWAP_ROUTER_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# Hyperliquid Bridge2 (Arbitrum → HL L1)
HL_BRIDGE_ADDRESS=0x2Df1c51E09aECF9cacB7bc98cB1742757f163dF7

# Chainlink price feeds
ETH_ORACLE_ADDRESS=0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
BTC_ORACLE_ADDRESS=0x6ce185860a4963106506C203335A2910413708e9

# ── HyperliquidAdapter deploy (scripts/deploy-hyperliquid-adapter.js) ─────────
# One adapter per vault. Pass the HL bridge as MOCK_HL_ADDRESS (script name is historical).
# MOCK_HL_ADDRESS=0x2Df1c51E09aECF9cacB7bc98cB1742757f163dF7
# USDC_ADDRESS=<same as above>
#
# KashYieldETH:  IS_ETH_ASSET=true   + KASH_YIELD_ETH_ADDRESS (WBTC not used)
# KashYieldBtc:  IS_ETH_ASSET=false  + KASH_YIELD_BTC_ADDRESS + WBTC_ADDRESS
#                (omit IS_ETH_ASSET or any value other than literal "true" → BTC / wBTC mode)
#
# Set exactly one for the adapter deploy you are running, e.g.:
# IS_ETH_ASSET=true
# or for KashYieldBtc.sol:
# IS_ETH_ASSET=false

# ── Deployed adapter addresses (fill in after each deploy step) ───────────────
UNISWAP_ADAPTER_ADDRESS=
HL_ADAPTER_ADDRESS_ETH=
HL_ADAPTER_ADDRESS_BTC=

# ── ExchangeFacade (one per vault — deploy-exchange-facade.js) ───────────────
# BTC: KASH_YIELD_ADDRESS=<vault> PRIMARY_ASSET=0x2f2a2543B76A4166549F7aaB2e75Bef0aefC5B0f
# ETH: KASH_YIELD_ADDRESS=<vault> PRIMARY_ASSET=0x0000000000000000000000000000000000000000
EXCHANGE_FACADE_ETH_ADDRESS=
EXCHANGE_FACADE_BTC_ADDRESS=

# ── Deployed KashYield contract addresses (fill in after deploy) ──────────────
KASH_YIELD_ETH_ADDRESS=
KASH_TOKEN_ETH=
KASH_YIELD_BTC_ADDRESS=
KASH_TOKEN_BTC=

# ── Frontend (frontend/.env.local) — mirror vault/token addresses with NEXT_PUBLIC_ prefix ─
# NEXT_PUBLIC_KASH_YIELD_ETH_ADDRESS=
# NEXT_PUBLIC_KASH_TOKEN_ETH=
# NEXT_PUBLIC_KASH_YIELD_BTC_ADDRESS=
# NEXT_PUBLIC_KASH_TOKEN_BTC=
# See frontend/.env.example
