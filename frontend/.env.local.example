# =============================================================================
# FRONTEND .env.local — Next.js app (local dev + Vercel)
# Copy to .env.local and fill in values. Never commit the real .env.local file.
#
#   cp .env.local.example .env.local
#
# Use NEXT_PUBLIC_* for anything needed in the browser bundle.
# Restart `npm run dev` (or redeploy on Vercel) after changing env vars.
# =============================================================================

# ── WalletConnect (RainbowKit) ───────────────────────────────────────────────
# Create a project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── App / chain ───────────────────────────────────────────────────────────────
# Public site URL (WalletConnect metadata). Defaults to https://kashyield.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Arbitrum One JSON-RPC. Defaults to https://arb1.arbitrum.io/rpc
# NEXT_PUBLIC_RPC_URL=https://arb1.g.alchemy.com/v2/YOUR_API_KEY

# ── Deployed contracts (mirror root .env after deploy) ────────────────────────
# KASH-BTC V3 (Aster): from deploy-kash-btc-aster-stack.js / npm run deploy:btc-aster
# KASH-ETH: from deploy-kashyieldeth.js (+ HL wiring)
# Prefer NEXT_PUBLIC_* — required for client-side reads and writes.
NEXT_PUBLIC_KASH_YIELD_ETH_ADDRESS=0x...
NEXT_PUBLIC_KASH_TOKEN_ETH=0x...
NEXT_PUBLIC_KASH_YIELD_BTC_ADDRESS=0x...
NEXT_PUBLIC_KASH_TOKEN_BTC=0x...

# Local Hardhat / testnet only — mainnet uses canonical wBTC (hardcoded fallback)
# NEXT_PUBLIC_MOCK_WBTC=0x...

# Non-prefixed aliases also work via next.config.js env mapping (server/build only).
# KASH_YIELD_ETH_ADDRESS=
# KASH_TOKEN_ETH=
# KASH_YIELD_BTC_ADDRESS=
# KASH_TOKEN_BTC=
# MOCK_WBTC=

# ── Merkle claim proofs (optional) ───────────────────────────────────────────
# Defaults to static paths served from frontend/public/
# NEXT_PUBLIC_MINT_PROOF_BASE_URL=/mint-proofs
# NEXT_PUBLIC_REDEEM_PROOF_BASE_URL=/redeem-proofs

# ── Strategy yield display (optional) ───────────────────────────────────────
# Used on the landing page strategy breakdown. Defaults: 70% LTV, 1.7x short leverage.
# NEXT_PUBLIC_BORROW_LTV_PCT=70
# NEXT_PUBLIC_SHORT_LEVERAGE=1.7

# ── Server-only (API routes — do NOT prefix with NEXT_PUBLIC_) ───────────────
# Recent activity feed (/api/activity). Same unified key as Hardhat verify.
# Also readable from repo root ../.env if not set here.
# ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional overrides for server-side RPC / Hyperliquid API
# ARBITRUM_RPC_URL=
# RPC_URL=
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
