# Copy to frontend/.env.local — restart dev server after changes; redeploy production on Vercel.
# Next.js only exposes NEXT_PUBLIC_* to the browser.

# ── KASH-ETH (Arbitrum One) ───────────────────────────────────────────────────
NEXT_PUBLIC_KASH_YIELD_ETH_ADDRESS=
NEXT_PUBLIC_KASH_TOKEN_ETH=

# ── KASH-BTC (Arbitrum One) ───────────────────────────────────────────────────
NEXT_PUBLIC_KASH_YIELD_BTC_ADDRESS=
NEXT_PUBLIC_KASH_TOKEN_BTC=

# ── Reown / WalletConnect (optional — Rabby & browser extensions work without) ─
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Redeem Merkle proofs (published by bot after Phase 2) ─────────────────────
NEXT_PUBLIC_REDEEM_PROOF_BASE_URL=
